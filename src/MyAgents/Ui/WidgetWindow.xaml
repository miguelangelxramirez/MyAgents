<Window x:Class="MyAgents.Ui.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:MyAgents.Ui"
        Title="MyAgents"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        SizeToContent="Height" Width="346"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True" FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>

        <!-- Slim, subtle scrollbar (replaces the chunky default) -->
        <Style x:Key="SlimThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#55FFFFFF" Margin="1,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NoButton" TargetType="RepeatButton">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NoButton}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NoButton}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header / row icon buttons -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{x:Static ui:Palette.TextMuted}"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{x:Static ui:Palette.RowHover}"/>
                                <Setter Property="Foreground" Value="{x:Static ui:Palette.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A session row, rendered as a borderless click button -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="0" Height="60">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{x:Static ui:Palette.RowHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded usage bar -->
        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="7"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="{x:Static ui:Palette.BarTrack}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border CornerRadius="3.5" Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    CornerRadius="3.5" Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The row template -->
        <DataTemplate x:Key="SessionTemplate">
            <Button Style="{StaticResource RowButton}" Click="Row_Click" Margin="6,1,6,1">
                <Grid Height="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3"/>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- accent bar: always the PROVIDER colour (Claude orange / Codex teal),
                         so you can tell providers apart at rest. The moving glyph (arc/dot)
                         keeps the state colour. -->
                    <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="0,8"
                            Background="{Binding ProviderBrush}"/>

                    <!-- status glyph -->
                    <Grid Grid.Column="1" Width="18" Height="18" HorizontalAlignment="Center">
                        <!-- busy: a little generic robot that bobs (NOT Anthropic's mark) -->
                        <Canvas Width="18" Height="18"
                                Visibility="{Binding IsBusy, Converter={StaticResource B2V}}"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <TranslateTransform x:Name="bob" Y="0"/>
                            </Canvas.RenderTransform>
                            <!-- antenna -->
                            <Rectangle Canvas.Left="8.5" Canvas.Top="1.5" Width="1" Height="3" Fill="{Binding Accent}"/>
                            <Ellipse Canvas.Left="7.5" Canvas.Top="0" Width="3" Height="3" Fill="{Binding Accent}"/>
                            <!-- head -->
                            <Border Canvas.Left="3" Canvas.Top="4.5" Width="12" Height="10" CornerRadius="3"
                                    BorderBrush="{Binding Accent}" BorderThickness="1.5"/>
                            <!-- eyes -->
                            <Ellipse Canvas.Left="6" Canvas.Top="8" Width="2.2" Height="2.2" Fill="{Binding Accent}"/>
                            <Ellipse Canvas.Left="9.8" Canvas.Top="8" Width="2.2" Height="2.2" Fill="{Binding Accent}"/>
                            <Canvas.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bob"
                                                Storyboard.TargetProperty="Y"
                                                From="0" To="-2" Duration="0:0:0.5"
                                                AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Canvas.Triggers>
                        </Canvas>
                        <!-- permission: breathing dot -->
                        <Ellipse Width="10" Height="10"
                                 Visibility="{Binding IsPermission, Converter={StaticResource B2V}}"
                                 Fill="{Binding Accent}" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                From="0.45" To="1" Duration="0:0:0.8"
                                                AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <!-- idle: small dot -->
                        <Ellipse Width="8" Height="8"
                                 Visibility="{Binding IsIdle, Converter={StaticResource B2V}}"
                                 Fill="{Binding Accent}"/>
                    </Grid>

                    <!-- texts: name · folder · state -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="2,0,6,0">
                        <TextBlock Text="{Binding Title}" Foreground="{x:Static ui:Palette.TextPrimary}"
                                   FontSize="12.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Folder}" Foreground="{x:Static ui:Palette.TextMuted}"
                                   FontSize="10.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Folder}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Action}" Foreground="{Binding ActionBrush}"
                                   FontSize="10.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- provider badge + pending dot -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <Border CornerRadius="4" Background="{Binding ProviderBg}" Padding="5,1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding ProviderLabel}" Foreground="{Binding ProviderBrush}"
                                       FontSize="9.5" FontWeight="SemiBold"/>
                        </Border>
                        <Ellipse Width="7" Height="7" Margin="0,6,1,0" HorizontalAlignment="Right"
                                 Fill="{Binding ProviderBrush}"
                                 Visibility="{Binding Pending, Converter={StaticResource B2V}}"
                                 ToolTip="Finished — not opened yet"/>
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <!-- Glass card -->
    <Border CornerRadius="10" Background="{x:Static ui:Palette.GlassTint}"
            BorderBrush="{x:Static ui:Palette.Stroke}" BorderThickness="1">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="Row0" Height="Auto"/>
                <RowDefinition x:Name="Row1" Height="*"/>
                <RowDefinition x:Name="Row2" Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (drag handle) -->
            <Border x:Name="HeaderBar" Grid.Row="0" Height="36" Background="{x:Static ui:Palette.HeaderTint}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="Header_Drag" Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Settings gear sits on the side AWAY from the screen edge so its menu
                         opens into empty space, never over the app. Toggled in ApplyLayout. -->
                    <Button Grid.Column="0" x:Name="SettingsBtnLeft" Style="{StaticResource IconButton}"
                            Content="⚙" Click="Settings_Click" ToolTip="Settings" Visibility="Collapsed" Margin="6,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding HeaderText}" Margin="13,0,0,0"
                               VerticalAlignment="Center" Foreground="{x:Static ui:Palette.TextSecondary}"
                               FontSize="12" FontWeight="SemiBold"/>
                    <!-- Passive "update available" link (only shown when a newer release exists).
                         Clicking opens the Releases page — the app never self-updates. -->
                    <TextBlock Grid.Column="2" Text="{Binding UpdateText}" VerticalAlignment="Center"
                               Margin="6,0,4,0" FontSize="10.5" FontWeight="SemiBold" Cursor="Hand"
                               Foreground="{x:Static ui:Palette.Permission}"
                               ToolTip="A newer version is available — click to open the Releases page"
                               MouseLeftButtonUp="Update_Click"
                               Visibility="{Binding UpdateAvailable, Converter={StaticResource B2V}}"/>
                    <Button Grid.Column="3" x:Name="SettingsBtnRight" Style="{StaticResource IconButton}"
                            Content="⚙" Click="Settings_Click" ToolTip="Settings"/>
                    <Button Grid.Column="4" x:Name="CollapseBtn" Style="{StaticResource IconButton}"
                            Content="▾" Click="Collapse_Click"/>
                    <Button Grid.Column="5" Style="{StaticResource IconButton}"
                            Content="✕" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Session list -->
            <Grid Grid.Row="1" x:Name="BodyArea">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Section caption so the first row is never mistaken for a title -->
                <TextBlock Grid.Row="0" Text="SESSIONS" Margin="13,7,0,4"
                           Foreground="{x:Static ui:Palette.TextMuted}" FontSize="9.5"
                           FontWeight="SemiBold" Opacity="0.8"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="336" Margin="0,0,0,2">
                    <ItemsControl x:Name="SessionList" ItemsSource="{Binding Sessions}"
                                  ItemTemplate="{StaticResource SessionTemplate}"/>
                </ScrollViewer>
                <TextBlock Grid.Row="1" Text="No active sessions" Foreground="{x:Static ui:Palette.TextMuted}"
                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,18"
                           Visibility="{Binding IsEmpty, Converter={StaticResource B2V}}"/>
            </Grid>

            <!-- Usage footer -->
            <Border Grid.Row="2" x:Name="UsageArea" Padding="12,8,12,10"
                    BorderBrush="{x:Static ui:Palette.Stroke}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <!-- status line when no data -->
                    <TextBlock Text="{Binding Usage.StatusText}" Foreground="{x:Static ui:Palette.TextMuted}"
                               FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Usage.HasData}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Claude bars when data -->
                    <StackPanel Visibility="{Binding Usage.HasData, Converter={StaticResource B2V}}">
                        <TextBlock Text="Claude" Foreground="{x:Static ui:Palette.ProviderClaude}"
                                   FontSize="9.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="138"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="5h" Foreground="{x:Static ui:Palette.TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource UsageBar}"
                                         Value="{Binding Usage.SessionPercent, Mode=OneWay}"
                                         Foreground="{Binding Usage.SessionBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Usage.SessionText}" Margin="10,0,0,0"
                                       Foreground="{x:Static ui:Palette.TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="138"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="7d" Foreground="{x:Static ui:Palette.TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource UsageBar}"
                                         Value="{Binding Usage.WeeklyPercent, Mode=OneWay}"
                                         Foreground="{Binding Usage.WeeklyBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Usage.WeeklyText}" Margin="10,0,0,0"
                                       Foreground="{x:Static ui:Palette.TextSecondary}" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Age note (only when the capture is old / session idle). Keeps the reset
                             countdown on the bars above; this is its own line so nothing shrinks. -->
                        <TextBlock Text="{Binding Usage.StaleNote}" Foreground="{x:Static ui:Palette.TextMuted}"
                                   FontSize="9.5" Margin="24,3,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Usage.StaleNote}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Codex bars when data -->
                    <StackPanel Visibility="{Binding CodexUsage.HasData, Converter={StaticResource B2V}}" Margin="0,8,0,0">
                        <TextBlock Text="Codex" Foreground="{x:Static ui:Palette.ProviderCodex}"
                                   FontSize="9.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="138"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="5h" Foreground="{x:Static ui:Palette.TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource UsageBar}"
                                         Value="{Binding CodexUsage.SessionPercent, Mode=OneWay}"
                                         Foreground="{Binding CodexUsage.SessionBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding CodexUsage.SessionText}" Margin="10,0,0,0"
                                       Foreground="{x:Static ui:Palette.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="138"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="7d" Foreground="{x:Static ui:Palette.TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource UsageBar}"
                                         Value="{Binding CodexUsage.WeeklyPercent, Mode=OneWay}"
                                         Foreground="{Binding CodexUsage.WeeklyBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding CodexUsage.WeeklyText}" Margin="10,0,0,0"
                                       Foreground="{x:Static ui:Palette.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
