    "onboarding.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MyAgents adds a few local hooks to ~/.claude so it can show what each Claude Code and Codex session is doing. Everything stays on your Mac — no tokens, no network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MyAgents añade unos hooks locales en ~/.claude para mostrar qué hace cada sesión de Claude Code y Codex. Todo se queda en tu Mac: sin tokens ni conexión."
          }
        }
      }
    },
